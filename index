<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>AR เก็บขยะแยกประเภท</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { overflow: hidden; background: #000; font-family: 'Segoe UI', sans-serif; touch-action: none; }

  #camera-bg {
    position: fixed; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
    transform: scaleX(-1);
  }

  #no-camera {
    position: fixed; inset: 0;
    background: linear-gradient(135deg, #1a3a2a 0%, #0d2018 50%, #1a2a3a 100%);
    z-index: 0;
    display: none;
  }
  #no-camera .grid {
    position: absolute; inset: 0;
    background-image: 
      linear-gradient(rgba(0,200,100,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,200,100,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  #game-canvas {
    position: fixed; inset: 0;
    width: 100%; height: 100%;
    z-index: 10;
    pointer-events: none;
  }

  #ui-layer {
    position: fixed; inset: 0;
    z-index: 20;
    pointer-events: none;
  }

  #hud {
    position: absolute;
    top: 0; left: 0; right: 0;
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    background: linear-gradient(to bottom, rgba(0,0,0,0.6), transparent);
    pointer-events: all;
  }

  #score-box { display: flex; flex-direction: column; align-items: flex-start; }
  #score-label { font-size: 11px; color: rgba(255,255,255,0.7); letter-spacing: 1px; text-transform: uppercase; }
  #score-val { font-size: 32px; font-weight: 700; color: #fff; line-height: 1; text-shadow: 0 2px 8px rgba(0,0,0,0.5); }

  #lives-box { display: flex; gap: 6px; align-items: center; padding-top: 6px; }
  .life-icon { font-size: 22px; transition: transform 0.3s; }
  .life-icon.lost { opacity: 0.2; transform: scale(0.8); }

  #timer-box { display: flex; flex-direction: column; align-items: center; }
  #timer-label { font-size: 11px; color: rgba(255,255,255,0.7); letter-spacing: 1px; text-transform: uppercase; }
  #timer-val { font-size: 32px; font-weight: 700; color: #fff; line-height: 1; text-shadow: 0 2px 8px rgba(0,0,0,0.5); }
  #timer-val.warning { color: #ff6b6b; animation: pulse 0.5s infinite alternate; }

  #level-badge {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 12px; font-weight: 600; color: #fff;
    align-self: center;
  }

  #bins-bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 0 8px 16px;
    display: flex;
    justify-content: space-around;
    align-items: flex-end;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    pointer-events: all;
  }

  .bin {
    display: flex; flex-direction: column; align-items: center;
    cursor: pointer;
    transition: transform 0.15s;
    min-width: 60px;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .bin:active { transform: scale(0.92); }
  .bin.highlight { animation: binPulse 0.4s ease-out; }
  .bin.correct-flash { animation: correctFlash 0.4s ease-out; }
  .bin.wrong-flash { animation: wrongFlash 0.4s ease-out; }

  .bin-icon { font-size: 42px; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5)); transition: transform 0.15s; }
  .bin-label { font-size: 10px; font-weight: 700; color: #fff; text-shadow: 0 1px 4px rgba(0,0,0,0.8); text-align: center; margin-top: 2px; letter-spacing: 0.5px; }
  .bin-count { font-size: 9px; color: rgba(255,255,255,0.6); margin-top: 1px; }

  #active-item-panel {
    position: absolute;
    bottom: 110px; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: 10px 24px;
    display: flex; align-items: center; gap: 10px;
    pointer-events: none;
    transition: opacity 0.3s;
    white-space: nowrap;
  }
  #active-item-panel.hidden { opacity: 0; }
  #active-emoji { font-size: 28px; }
  #active-name { font-size: 14px; font-weight: 600; color: #fff; }
  #active-hint { font-size: 11px; color: rgba(255,255,255,0.6); margin-top: 2px; }

  .trash-item {
    position: absolute;
    cursor: grab;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    transform-origin: center;
    font-size: 40px;
    line-height: 1;
    text-shadow: 0 4px 12px rgba(0,0,0,0.4);
    transition: filter 0.1s;
    pointer-events: all;
    touch-action: none;
  }
  .trash-item:active { cursor: grabbing; }
  .trash-item.dragging { filter: drop-shadow(0 0 12px rgba(255,255,255,0.8)); z-index: 100; font-size: 48px; }
  .trash-item.collected { animation: collectOut 0.3s ease-out forwards; }
  .trash-item.float-anim { animation: floatBob 2s ease-in-out infinite; }

  .score-popup { position: absolute; font-size: 22px; font-weight: 800; pointer-events: none; animation: scoreFloat 1s ease-out forwards; text-shadow: 0 2px 8px rgba(0,0,0,0.6); z-index: 50; }

  #combo-display {
    position: absolute;
    top: 100px; left: 50%; transform: translateX(-50%);
    font-size: 28px; font-weight: 900;
    color: #FFD700;
    text-shadow: 0 0 20px rgba(255,215,0,0.8), 0 2px 8px rgba(0,0,0,0.6);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    white-space: nowrap;
  }
  #combo-display.show { opacity: 1; animation: comboAnim 0.5s ease-out; }

  .screen {
    position: fixed; inset: 0;
    z-index: 100;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(10px);
    padding: 24px;
    text-align: center;
  }
  .screen.hidden { display: none; }

  .screen h1 { font-size: 36px; font-weight: 900; color: #fff; text-shadow: 0 2px 20px rgba(0,200,100,0.5); margin-bottom: 8px; }
  .screen h2 { font-size: 26px; font-weight: 800; color: #fff; margin-bottom: 12px; }
  .screen p { font-size: 14px; color: rgba(255,255,255,0.7); max-width: 320px; line-height: 1.6; margin-bottom: 16px; }

  .btn-primary {
    background: linear-gradient(135deg, #00c853, #00897b);
    color: #fff; border: none;
    padding: 16px 48px;
    border-radius: 50px;
    font-size: 18px; font-weight: 700;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(0,200,83,0.4);
    margin: 8px;
    touch-action: manipulation;
  }
  .btn-primary:active { transform: scale(0.96); }

  .btn-secondary {
    background: rgba(255,255,255,0.1);
    color: #fff; border: 1px solid rgba(255,255,255,0.3);
    padding: 12px 36px;
    border-radius: 50px;
    font-size: 15px; font-weight: 600;
    cursor: pointer;
    margin: 8px;
    touch-action: manipulation;
  }
  .btn-secondary:active { background: rgba(255,255,255,0.2); }

  .big-emoji { font-size: 72px; margin-bottom: 16px; }
  .score-final { font-size: 52px; font-weight: 900; color: #FFD700; margin: 8px 0; text-shadow: 0 0 20px rgba(255,215,0,0.5); }
  .score-final-label { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 20px; }

  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 100%; max-width: 280px; margin: 12px auto; }
  .stat-card { background: rgba(255,255,255,0.08); border-radius: 12px; padding: 10px; }
  .stat-val { font-size: 22px; font-weight: 800; color: #fff; }
  .stat-lbl { font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.5px; margin-top: 2px; }

  .guide-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 12px 0; width: 100%; max-width: 340px; }
  .guide-bin { background: rgba(255,255,255,0.08); border-radius: 12px; padding: 10px 8px; display: flex; flex-direction: column; align-items: center; }
  .guide-bin .g-emoji { font-size: 32px; margin-bottom: 4px; }
  .guide-bin .g-name { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .guide-bin .g-items { font-size: 10px; color: rgba(255,255,255,0.6); line-height: 1.5; }

  .cam-status { position: absolute; top: 16px; right: 16px; font-size: 11px; color: rgba(255,255,255,0.5); background: rgba(0,0,0,0.4); padding: 4px 10px; border-radius: 12px; z-index: 25; }

  @keyframes floatBob { 0%, 100% { transform: translateY(0px) rotate(-3deg); } 50% { transform: translateY(-8px) rotate(3deg); } }
  @keyframes collectOut { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(2.5); opacity: 0; } }
  @keyframes scoreFloat { 0% { transform: translateY(0); opacity: 1; } 100% { transform: translateY(-60px); opacity: 0; } }
  @keyframes comboAnim { 0% { transform: translateX(-50%) scale(0.5); } 60% { transform: translateX(-50%) scale(1.2); } 100% { transform: translateX(-50%) scale(1); } }
  @keyframes pulse { from { opacity: 1; } to { opacity: 0.5; } }
  @keyframes binPulse { 0% { transform: scale(1); } 40% { transform: scale(1.2); } 100% { transform: scale(1); } }
  @keyframes correctFlash { 0% { filter: drop-shadow(0 0 0 rgba(0,255,100,0)); } 40% { filter: drop-shadow(0 0 20px rgba(0,255,100,1)); } 100% { filter: drop-shadow(0 0 0 rgba(0,255,100,0)); } }
  @keyframes wrongFlash { 0% { filter: drop-shadow(0 0 0 rgba(255,50,50,0)); } 40% { filter: drop-shadow(0 0 20px rgba(255,50,50,1)); } 100% { filter: drop-shadow(0 0 0 rgba(255,50,50,0)); } }
  @keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

  .screen > * { animation: slideUp 0.4s ease-out backwards; }
  .screen > *:nth-child(1) { animation-delay: 0.05s; }
  .screen > *:nth-child(2) { animation-delay: 0.1s; }
  .screen > *:nth-child(3) { animation-delay: 0.15s; }
  .screen > *:nth-child(4) { animation-delay: 0.2s; }
  .screen > *:nth-child(5) { animation-delay: 0.25s; }

  @media (max-height: 600px) {
    .big-emoji { font-size: 48px; margin-bottom: 8px; }
    .screen h1 { font-size: 28px; }
    .bin-icon { font-size: 34px; }
  }
</style>
</head>
<body>

<video id="camera-bg" autoplay playsinline muted></video>
<div id="no-camera"><div class="grid"></div></div>
<div id="cam-status" class="cam-status">📷 กำลังเปิดกล้อง...</div>
<div id="game-canvas"></div>

<div id="ui-layer">
  <div id="hud">
    <div id="score-box">
      <div id="score-label">คะแนน</div>
      <div id="score-val">0</div>
    </div>
    <div id="level-badge">ด่าน 1</div>
    <div>
      <div id="lives-box">
        <span class="life-icon">❤️</span>
        <span class="life-icon">❤️</span>
        <span class="life-icon">❤️</span>
      </div>
      <div id="timer-box" style="text-align:center; margin-top:4px;">
        <div id="timer-label">เวลา</div>
        <div id="timer-val">60</div>
      </div>
    </div>
  </div>

  <div id="active-item-panel"
